{
  "manifest_version": 3,
  "name": "8 Ball Pool Helper",
  "version": "1.1.0",
  "description": "A manual practice overlay to draw aim guide lines and cushion-reflection angles. You place every point by hand — no game data is read.",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "8 Ball Pool Helper (Alt+G)",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.8ballpool.com/*", "https://8ballpool.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-overlay": {
      "suggested_key": { "default": "Alt+G" },
      "description": "Toggle the guide overlay"
    }
  }
}
